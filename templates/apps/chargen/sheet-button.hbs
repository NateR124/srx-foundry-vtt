{{!--
  Optional in-template placement of the M7 "Create / Advance" launch button.
  The default wiring is JS-side via registerChargenHooks() (module/chargen/hooks.mjs),
  which injects this same control at render time without editing the frozen
  sheet class. Use this snippet only if the orchestrator prefers placing the
  button directly in templates/actor/character-sheet.hbs (e.g. inside .name-row).
  Requires an actor-sheet action mapping `openChargen` if wired this way, OR
  keep the JS click handler from hooks.mjs.
--}}
<a class="srx-chargen-launch" data-action="openChargen" title="{{localize 'SRX.Chargen.launch'}}">
  <i class="fa-solid fa-user-gear"></i> {{localize "SRX.Chargen.launchShort"}}
</a>
