{{!-- SRX priority chargen wizard. All rules live in module/apps/chargen/priority.mjs --}}
<div class="srx chargen-wizard">

  <nav class="chargen-steps">
    {{#each steps}}
    <a class="chargen-step {{#if this.active}}active{{/if}} {{#if this.done}}done{{/if}}"
       data-action="goStep" data-step="{{this.key}}">
      <span class="step-num">{{this.index}}</span>
      <span class="step-label">{{this.label}}</span>
    </a>
    {{/each}}
  </nav>

  <section class="chargen-body">

    {{#if (srxEq step "priorities")}}
    <div class="step-title">{{localize "SRX.Chargen.step.priorities"}}</div>
    <p class="hint">{{localize "SRX.Chargen.prioritiesHint"}}</p>
    <table class="priority-grid">
      <thead>
        <tr>
          <th>{{localize "SRX.Chargen.categoryHeader"}}</th>
          {{#each priorities.rows}}<th>{{this}}</th>{{/each}}
        </tr>
      </thead>
      <tbody>
        {{#each priorities.categories}}
        <tr>
          <th class="cat">{{this.label}}
            <span class="cat-pick {{#unless this.value}}unset{{/unless}}">{{#if this.value}}{{this.value}}{{else}}—{{/if}}</span>
          </th>
          {{#each this.cells}}
          <td class="pri-cell {{#if this.selected}}picked{{/if}}"
              data-action="pickPriority" data-cat="{{../key}}" data-row="{{this.row}}">{{this.text}}</td>
          {{/each}}
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{#if priorities.complete}}
    <p class="chargen-ok"><i class="fa-solid fa-circle-check"></i> {{localize "SRX.Chargen.prioritiesComplete"}}</p>
    {{else}}
    <p class="chargen-note"><i class="fa-solid fa-circle-exclamation"></i> {{localize "SRX.Chargen.assignAll"}}</p>
    {{/if}}
    {{/if}}

    {{#if (srxEq step "metatype")}}
    <div class="step-title">{{localize "SRX.Chargen.step.metatype"}}</div>
    <p class="hint">{{localize "SRX.Chargen.metatypeHint"}} ({{localize "SRX.Chargen.priority"}} {{metatype.priority}})</p>
    <p class="hint meta-avail">{{localize "SRX.Chargen.metatypeAvailable"}}: <b>{{metatype.availableNames}}</b>{{#if metatype.elsewhereNames}} · {{localize "SRX.Chargen.metatypeElsewhere"}}: {{metatype.elsewhereNames}}{{/if}}</p>
    <div class="metatype-list">
      {{#each metatype.list}}
      <label class="metatype-option {{#if this.selected}}picked{{/if}}">
        <input type="radio" name="metatype" value="{{this.key}}" {{#if this.selected}}checked{{/if}}>
        <span class="opt-check"><i class="fa-solid fa-circle-check"></i></span>
        <span class="mt-name">{{this.label}}</span>
        <span class="mt-mods">{{this.mods}}</span>
        {{#if (srxNotNull this.karma)}}<span class="mt-karma">{{this.karma}} {{localize "SRX.Chargen.karma"}}</span>{{/if}}
      </label>
      {{/each}}
    </div>
    {{#if metatype.grantLabel}}<p class="chargen-ok grant"><i class="fa-solid fa-award"></i> {{metatype.grantLabel}}</p>{{/if}}
    {{#if metatype.maxima.length}}
    <div class="chargen-tiles maxima-strip">
      {{#each metatype.maxima}}
      <div class="chargen-tile"><b>{{this.value}}</b><span>{{this.abbr}}</span></div>
      {{/each}}
    </div>
    <p class="hint">{{localize "SRX.Chargen.maxima"}}</p>
    {{/if}}
    {{#if metatype.choice}}
    <div class="form-group">
      <label>{{localize "SRX.Chargen.metatypeChoice"}} ({{metatype.choice.amount}})</label>
      <select name="metatypeChoice">
        <option value="">{{localize "SRX.Metatype.choiceNone"}}</option>
        {{#each metatype.choice.options}}
        <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}
    {{/if}}

    {{#if (srxEq step "attributes")}}
    <div class="step-title">{{localize "SRX.Chargen.step.attributes"}}</div>
    <p class="budget chargen-budget {{#if attributes.over}}over{{/if}}" data-kind="attr" data-available="{{attributes.available}}">
      {{localize "SRX.Chargen.points"}}: <b class="b-spent">{{attributes.spent}}</b> / {{attributes.available}}
      (<span class="b-remaining">{{attributes.remaining}}</span> {{localize "SRX.Chargen.remaining"}})
    </p>
    <table class="attribute-grid">
      <thead><tr>
        <th class="col-attr">{{localize "SRX.Chargen.attribute"}}</th>
        <th>{{localize "SRX.Chargen.base"}}</th>
        <th>{{localize "SRX.Chargen.total"}}</th>
        <th>{{localize "SRX.Chargen.max"}}</th>
      </tr></thead>
      <tbody>
        {{#each attributes.rows}}
        <tr>
          <th class="col-attr"><b>{{this.abbr}}</b> <span class="attr-name">{{this.label}}</span></th>
          <td class="base-cell">
            <span class="stepper">
              <a class="step-btn" data-action="stepAttr" data-key="{{this.key}}" data-delta="-1" title="−1">−</a>
              <input type="number" name="attr.{{this.key}}" value="{{this.base}}" min="1" max="6" step="1">
              <a class="step-btn" data-action="stepAttr" data-key="{{this.key}}" data-delta="1" title="+1">+</a>
            </span>
          </td>
          <td class="unaug">{{this.unaug}}{{#if this.modLabel}} <span class="mod">{{this.modLabel}}</span>{{/if}}</td>
          <td class="max">{{this.max}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <p class="hint">{{localize "SRX.Chargen.attributeCostHint"}}</p>
    {{/if}}

    {{#if (srxEq step "magic")}}
    <div class="step-title">{{localize "SRX.Chargen.step.magic"}}</div>
    {{#if magic.mundane}}
    <p class="hint">{{localize "SRX.Chargen.mundane"}}</p>
    {{else}}
    <p class="hint">{{localize "SRX.Chargen.magicHint"}}</p>
    <div class="form-group">
      <label>{{localize "SRX.Chargen.awakenedType"}}</label>
      <select name="awakened">
        <option value="" {{#unless magic.awakened}}selected{{/unless}}>{{localize "SRX.Chargen.mundaneOption"}}</option>
        <option value="magic" {{#if magic.isMagic}}selected{{/if}}>{{localize "SRX.Chargen.magicOption"}}</option>
        <option value="resonance" {{#if magic.isResonance}}selected{{/if}}>{{localize "SRX.Chargen.resonanceOption"}}</option>
      </select>
    </div>
    <div class="form-group">
      <label>{{localize "SRX.Chargen.essence"}}</label>
      <input type="number" name="essence" value="{{magic.essence}}" min="0" max="6" step="0.05">
    </div>
    <div class="chargen-tiles">
      <div class="chargen-tile big"><b>{{magic.rating}}</b><span>{{localize "SRX.Chargen.rating"}}</span></div>
    </div>
    <p class="hint magic-readout">= min(WIL {{magic.wil}}, {{localize "SRX.Chargen.max"}} {{magic.max}}, ⌊Essence⌋ {{magic.essence}})</p>
    <p class="hint">{{localize "SRX.Chargen.karmaPool"}}: {{magic.karma}} ({{localize "SRX.Chargen.restrictedKarma"}})</p>
    {{/if}}
    {{/if}}

    {{#if (srxEq step "skills")}}
    <div class="step-title">{{localize "SRX.Chargen.step.skills"}}</div>
    <p class="budget chargen-budget {{#if skills.over}}over{{/if}}" data-kind="skill" data-available="{{skills.available}}">
      {{localize "SRX.Chargen.points"}}: <b class="b-spent">{{skills.spent}}</b> / {{skills.available}}
      (<span class="b-remaining">{{skills.remaining}}</span> {{localize "SRX.Chargen.remaining"}})
    </p>
    <table class="skill-grid">
      <tbody>
        {{#each skills.rows}}
        <tr>
          <th>{{this.label}} <span class="linked">{{this.linked}}</span></th>
          <td class="base-cell">
            <span class="stepper">
              <a class="step-btn" data-action="stepSkill" data-key="{{this.key}}" data-delta="-1" title="−1">−</a>
              <input type="number" name="skill.{{this.key}}" value="{{this.rating}}" min="0" max="6" step="1">
              <a class="step-btn" data-action="stepSkill" data-key="{{this.key}}" data-delta="1" title="+1">+</a>
            </span>
          </td>
          <td class="spec-cell">
            {{#each this.specializations}}
            <span class="spec-tag">{{this}}
              <a data-action="removeSpec" data-skill="{{../key}}" data-index="{{@index}}" title="{{localize 'SRX.Chargen.removeSpec'}}">×</a>
            </span>
            {{/each}}
            {{#if this.canSpecialize}}
            <span class="spec-add">
              <input type="text" data-spec-for="{{this.key}}" placeholder="{{localize 'SRX.Chargen.specPlaceholder'}}">
              <a data-action="addSpec" data-skill="{{this.key}}" title="{{localize 'SRX.Chargen.addSpec'}}">+</a>
            </span>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <p class="hint">{{localize "SRX.Chargen.skillCostHint"}}</p>
    {{/if}}

    {{#if (srxEq step "resources")}}
    <div class="step-title">{{localize "SRX.Chargen.step.resources"}}</div>
    <p class="hint">{{localize "SRX.Chargen.resourcesHint"}}</p>
    <div class="chargen-tiles">
      <div class="chargen-tile"><b>{{resources.available}}¥</b><span>{{localize "SRX.Chargen.nuyenBudget"}}</span></div>
      <div class="chargen-tile"><b>{{resources.carryover}}¥</b><span>{{localize "SRX.Chargen.carryover"}}</span></div>
    </div>
    <div class="form-group">
      <label>{{localize "SRX.Chargen.nuyenSpent"}}</label>
      <input type="number" name="nuyenSpent" value="{{resources.spent}}" min="0" step="100">
    </div>
    {{#if resources.forfeited}}
    <p class="magic-readout"><span class="warn">{{resources.forfeited}}¥ {{localize "SRX.Chargen.forfeited"}}</span></p>
    {{/if}}
    <div class="form-group">
      <label>{{localize "SRX.Chargen.lifestyle"}}</label>
      <select name="lifestyle">
        {{#each resources.lifestyles}}
        <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}

    {{#if (srxEq step "talents")}}
    <div class="step-title">{{localize "SRX.Chargen.step.talents"}}</div>
    {{#unless talents.hasCatalog}}
    <p class="chargen-note">{{localize "SRX.Chargen.noTalentCatalog"}}</p>
    {{else}}
    <p class="budget">
      {{localize "SRX.Chargen.generalKarma"}}: <b>{{talents.generalSpent}}</b> / {{talents.generalAvail}} ·
      {{localize "SRX.Chargen.magicKarma"}}: <b>{{talents.magicSpent}}</b> / {{talents.magicAvail}}
    </p>
    <div class="talent-list">
      {{#each talents.catalog}}
      <label class="talent-option {{#if this.chosen}}picked{{/if}}">
        <input type="checkbox" name="talent.{{this.id}}" data-item-id="{{this.id}}" {{#if this.chosen}}checked{{/if}}>
        <span class="opt-check"><i class="fa-solid fa-circle-check"></i></span>
        <span class="t-name">{{this.name}}</span>
        <span class="t-karma">{{this.karma}}k</span>
        <select data-pool-for="{{this.id}}" class="t-pool">
          <option value="general">{{localize "SRX.Chargen.poolGeneral"}}</option>
          <option value="magic" {{#if this.magical}}selected{{/if}}>{{localize "SRX.Chargen.poolMagic"}}</option>
        </select>
      </label>
      {{/each}}
    </div>
    <p class="hint">{{localize "SRX.Chargen.talentsHint"}}</p>
    {{/unless}}
    {{/if}}

    {{#if (srxEq step "review")}}
    <div class="step-title">{{localize "SRX.Chargen.step.review"}}</div>
    {{#if review.legal}}
    <p class="verdict legal"><i class="fa-solid fa-circle-check"></i> {{localize "SRX.Chargen.legal"}}</p>
    {{else}}
    <p class="verdict illegal"><i class="fa-solid fa-circle-xmark"></i> {{localize "SRX.Chargen.illegal"}}</p>
    <ul class="problem-list">{{#each review.problems}}<li>{{this}}</li>{{/each}}</ul>
    {{/if}}
    {{#if review.warnings.length}}
    <ul class="warning-list">{{#each review.warnings}}<li>{{this}}</li>{{/each}}</ul>
    {{/if}}
    {{#if review.wellRounded.length}}
    <p class="hint">{{localize "SRX.Chargen.wellRoundedNote"}}</p>
    <ul class="warning-list">{{#each review.wellRounded}}<li>{{this}}</li>{{/each}}</ul>
    {{/if}}

    <div class="review-recap">
      <div class="recap-block">
        <div class="section-label">{{localize "SRX.Chargen.review.identity"}}</div>
        <dl class="review-summary">
          <dt>{{localize "SRX.Chargen.metatype"}}</dt><dd>{{review.metatypeLabel}}</dd>
          {{#if review.awakenedLabel}}<dt>{{localize "SRX.Chargen.rating"}}</dt><dd>{{review.awakenedLabel}} {{review.summary.magicRating}}</dd>{{/if}}
          <dt>{{localize "SRX.Chargen.lifestyle"}}</dt><dd>{{review.lifestyleLabel}} (Fake SIN {{review.fakeSin}})</dd>
          <dt>{{localize "SRX.Chargen.nuyen"}}</dt><dd>{{review.summary.nuyen}}¥</dd>
          <dt>{{localize "SRX.Chargen.knowledgeSlots"}}</dt><dd>{{review.summary.knowledgeDomainSlots}}</dd>
          <dt>{{localize "SRX.Chargen.contactSlots"}}</dt><dd>{{review.summary.contactSlots}}</dd>
        </dl>
        <div class="priorities-recap">
          {{#each review.priorities}}<span class="pri-chip">{{this.label}} <b>{{this.row}}</b></span>{{/each}}
        </div>
      </div>

      <div class="recap-block">
        <div class="section-label">{{localize "SRX.Chargen.step.attributes"}}</div>
        <div class="attr-recap">
          {{#each review.attributes}}
          <div class="chargen-tile"><b>{{this.value}}</b><span>{{this.abbr}}</span></div>
          {{/each}}
        </div>
      </div>

      {{#if review.skills.length}}
      <div class="recap-block">
        <div class="section-label">{{localize "SRX.Chargen.step.skills"}}</div>
        <ul class="skill-recap">
          {{#each review.skills}}
          <li><span class="sk-name">{{this.label}}</span> <b>{{this.rating}}</b>{{#if this.specs}} <span class="sk-spec">({{this.specs}})</span>{{/if}}</li>
          {{/each}}
        </ul>
      </div>
      {{/if}}

      {{#if review.talents.length}}
      <div class="recap-block">
        <div class="section-label">{{localize "SRX.Chargen.step.talents"}}</div>
        <ul class="talent-recap">
          {{#each review.talents}}<li><span class="t-name">{{this.name}}</span> <span class="t-karma">{{this.karma}}k</span></li>{{/each}}
        </ul>
      </div>
      {{/if}}
    </div>
    {{/if}}

  </section>

  <footer class="chargen-nav">
    {{#unless isFirst}}<button type="button" data-action="back"><i class="fa-solid fa-arrow-left"></i> {{localize "SRX.Chargen.back"}}</button>{{/unless}}
    {{#if isLast}}
    <button type="button" class="commit" data-action="commit" {{#unless verdict.legal}}disabled{{/unless}}>
      <i class="fa-solid fa-user-check"></i> {{localize "SRX.Chargen.create"}}
    </button>
    {{else}}
    {{#if blockNext}}<span class="next-hint">{{localize "SRX.Chargen.nextNeedsPriorities"}}</span>{{/if}}
    <button type="button" class="next" data-action="next" {{#if blockNext}}disabled{{/if}}>{{localize "SRX.Chargen.next"}} <i class="fa-solid fa-arrow-right"></i></button>
    {{/if}}
  </footer>

</div>
