{{!-- SRX Karma advancement panel. Costs/validation: module/rules/karma.mjs --}}
<div class="srx advance-panel">

  <header class="advance-header">
    <div class="chargen-tiles karma-header">
      <div class="chargen-tile big balance"><b>{{balance}}</b><span>{{localize "SRX.Advance.available"}}</span></div>
      <div class="chargen-tile"><b>{{spent}}</b><span>{{localize "SRX.Advance.spent"}}</span></div>
      <label class="chargen-tile earned-tile">
        <input type="number" name="system.details.karma.earned" value="{{earned}}" min="0" step="1" {{#unless editable}}disabled{{/unless}}>
        <span>{{localize "SRX.Advance.earnedShort"}}</span>
      </label>
    </div>
  </header>

  {{#unless editable}}
  <p class="chargen-note">{{localize "SRX.Advance.notOwner"}}</p>
  {{/unless}}

  <section class="advance-grid">

    <div class="advance-col">
      <div class="section-label">{{localize "SRX.Advance.attributes"}}</div>
      <table class="advance-attributes">
        <tbody>
          {{#each attributes}}
          <tr>
            <th>{{this.abbr}}</th>
            <td class="rating">{{this.rating}}</td>
            <td class="buy">
              {{#if this.atMax}}<span class="atmax">{{localize "SRX.Advance.atMax"}}</span>
              {{else}}
              <button type="button" data-action="raiseAttribute" data-key="{{this.key}}" {{#unless this.canRaise}}disabled{{/unless}}>
                +1 <span class="cost">({{this.cost}})</span>
              </button>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    <div class="advance-col">
      <div class="section-label">{{localize "SRX.Advance.skills"}}</div>
      <table class="advance-skills">
        <tbody>
          {{#each skills}}
          <tr>
            <th>{{this.label}}</th>
            <td class="rating">{{this.rating}}</td>
            <td class="buy">
              {{#if this.atMax}}<span class="atmax">{{localize "SRX.Advance.atMax"}}</span>
              {{else}}
              <button type="button" data-action="raiseSkill" data-key="{{this.key}}" {{#unless this.canRaise}}disabled{{/unless}}>
                +1 <span class="cost">({{this.cost}})</span>
              </button>
              {{/if}}
            </td>
            <td class="spec">
              {{#each this.specializations}}<span class="spec-tag">{{this}}</span>{{/each}}
              {{#if this.canSpecialize}}
              <input type="text" data-spec-for="{{this.key}}" placeholder="{{localize 'SRX.Advance.specPlaceholder'}}">
              <button type="button" data-action="buySpec" data-key="{{this.key}}">+ {{localize "SRX.Advance.spec"}} <span class="cost">({{this.specCost}})</span></button>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

  </section>

  <section class="advance-extra">
    <div class="advance-knowledge">
      <div class="section-label">{{localize "SRX.Advance.knowledge"}}</div>
      <div class="knowledge-add">
        <input type="text" name="knowledgeName" placeholder="{{localize 'SRX.Advance.knowledgePlaceholder'}}">
        <select name="knowledgeKind">
          <option value="domain">{{localize "SRX.Advance.domain"}}</option>
          <option value="language">{{localize "SRX.Advance.language"}}</option>
        </select>
        <button type="button" data-action="buyKnowledge">+ {{localize "SRX.Advance.add"}} <span class="cost">({{knowledgeCost}})</span></button>
      </div>
    </div>

    <div class="advance-talents">
      <div class="section-label">{{localize "SRX.Advance.talents"}}</div>
      {{#unless hasCatalog}}
      <p class="chargen-note">{{localize "SRX.Advance.noTalentCatalog"}}</p>
      {{else}}
      <div class="talent-list">
        {{#each talents}}
        <div class="talent-row {{#if this.owned}}owned{{/if}}">
          <span class="t-name">{{this.name}}</span>
          <span class="t-karma">{{this.cost}}k</span>
          {{#if this.owned}}<span class="owned-tag">{{localize "SRX.Advance.owned"}}</span>
          {{else}}
          <button type="button" data-action="buyTalent" data-item-id="{{this.id}}" {{#unless this.canBuy}}disabled{{/unless}}>{{localize "SRX.Advance.buy"}}</button>
          {{/if}}
        </div>
        {{/each}}
      </div>
      {{/unless}}
    </div>
  </section>

  {{#if ledger.length}}
  <section class="advance-ledger">
    <div class="section-label">{{localize "SRX.Advance.ledger"}}</div>
    <ul>
      {{#each ledger}}
      <li><span class="l-label">{{this.label}}</span> <span class="l-cost">−{{this.cost}}</span></li>
      {{/each}}
    </ul>
  </section>
  {{/if}}

</div>
