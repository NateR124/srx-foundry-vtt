<div class="srx chat-card combat-card attack-outcome">
  <header class="card-header">
    <i class="fa-solid fa-crosshairs card-icon"></i>
    <h3>{{localize "SRX.Combat.hit"}}</h3>
    <span class="actor-name">{{attackerName}}</span>
  </header>
  <p>
    <b>{{attackerName}}</b> → <b>{{defenderName}}</b>
    {{#if weaponName}}({{weaponName}}){{/if}}
  </p>
  <div class="result-row">
    <span>{{hits}} {{localize "SRX.Roll.hits"}} vs DS {{defenseScore}}</span>
    <span class="detail">{{localize "SRX.Combat.netHits"}}: {{netHits}}</span>
  </div>
  <div class="dv-row">
    {{localize "SRX.Item.dv"}}:
    <b>{{totalDv}}{{dvType}}</b>
    {{#if element}}<span class="element">{{element}}</span>{{/if}}
    {{#if aoe}}<span class="fire-mode">AOE</span>{{/if}}
  </div>
  <div class="card-actions">
    <button type="button" class="srx-combat-btn primary" data-combat-action="resist">
      {{localize "SRX.Combat.resist"}}
    </button>
    <button type="button" class="srx-combat-btn" data-combat-action="applyUnresisted">
      {{localize "SRX.Combat.applyUnresisted"}}
    </button>
  </div>
</div>
